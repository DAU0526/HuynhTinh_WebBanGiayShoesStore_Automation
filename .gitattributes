# Tell GitHub Linguist to ignore generated/vendored files for language detection

# Ignore HTML test reports (Robot Framework / pytest generated output)
results/*.html linguist-generated=true
results/*.xml linguist-generated=true

# Ignore bat scripts
*.bat linguist-vendored=true

# Ignore Python POM/test files so Robot Framework is the primary language shown
tests/pom/**/*.py linguist-vendored=true
tests/selenium/*.py linguist-vendored=true
tests/test_register_automation.py linguist-vendored=true
conftest.py linguist-vendored=true

# Classify Robot Framework files correctly - make them detectable and dominant
*.robot linguist-language=RobotFramework linguist-detectable=true linguist-vendored=false
